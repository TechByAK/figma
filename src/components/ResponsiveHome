import { useEffect } from "react";
import { useNavigate } from "react-router-dom";

function ResponsiveHome() {
  const navigate = useNavigate();

  useEffect(() => {
    if (window.innerWidth >= 900) {
      navigate("/dashboard");
    } else {
      navigate("/home");
    }
  }, [navigate]);

  return null;
}

export default ResponsiveHome;